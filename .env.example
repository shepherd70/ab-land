# ab-land configuration. Copy to .env.local for overrides.
# No secrets required — all live data is open (OGL-Alberta).

# Base URL of the Alberta Energy GeoView ArcGIS REST services folder.
ARCGIS_BASE_URL=https://gis.energy.gov.ab.ca/arcgis/rest/services/Geoview

# Local SQLite database path (gitignored).
DB_PATH=./data/ab-land.sqlite

# Folder where you place lawfully obtained Altalis DIDs/DIDs+ files (gitignored).
ALTALIS_DIR=./data/altalis

# Ingest tuning.
INGEST_PAGE_SIZE=1000
INGEST_OUT_SR=4326
